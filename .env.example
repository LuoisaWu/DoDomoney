DODOMONEY_ENVIRONMENT=development
DODOMONEY_DATABASE_URL=sqlite:///./dodomoney.db
DODOMONEY_API_HOST=0.0.0.0
DODOMONEY_API_PORT=8000
DODOMONEY_CORS_ORIGINS=http://localhost:5173
DODOMONEY_REDIS_URL=redis://127.0.0.1:6379/0
DODOMONEY_VERIFICATION_CODE_SECRET=replace-with-a-long-random-secret
DODOMONEY_VERIFICATION_CODE_TTL_SECONDS=300
DODOMONEY_VERIFICATION_SEND_COOLDOWN_SECONDS=60
DODOMONEY_VERIFICATION_MAX_ATTEMPTS=5

# SMTP 邮件服务（生产环境必须配置）
DODOMONEY_SMTP_HOST=
DODOMONEY_SMTP_PORT=587
DODOMONEY_SMTP_USERNAME=
DODOMONEY_SMTP_PASSWORD=
DODOMONEY_SMTP_FROM_EMAIL=no-reply@example.com
DODOMONEY_SMTP_USE_SSL=false
DODOMONEY_SMTP_USE_TLS=true
# 仅限本地联调；生产环境保持 false
DODOMONEY_EXPOSE_VERIFICATION_CODE=false

# OpenAI Chat Completions 兼容模型；图片识别要求模型支持 image_url 输入
DODOMONEY_LLM_API_KEY=
DODOMONEY_LLM_BASE_URL=https://api.openai.com/v1
DODOMONEY_LLM_MODEL=gpt-4.1-mini
# 可选：文本模型不支持图片时，单独指定视觉模型
DODOMONEY_VISION_MODEL=
DODOMONEY_LLM_TIMEOUT_SECONDS=30
