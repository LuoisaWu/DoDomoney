# H5 / App 开发地址
VITE_API_BASE_URL=http://127.0.0.1:8000

# HBuilderX 通过 USB 运行到 Android 真机时，配合 start-phone-debug.bat 的 ADB reverse 使用。
# 无线调试时可在 App 登录页改为电脑局域网 IPv4。
VITE_APP_API_BASE_URL=http://127.0.0.1:8000

